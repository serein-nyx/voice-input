# ── DeepSeek 润色（必填）────────────────────────────
# 控制台：https://platform.deepseek.com/  →  API Keys
DEEPSEEK_API_KEY=sk-37223429260145d9938a936faa91dd42
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60

# ── STT (faster-whisper) ───────────────────────────
# 模型：tiny / base / small / medium / large-v3 / large-v3-turbo
STT_ENGINE=paraformer
WHISPER_MODEL=large-v3
# device: auto(优先GPU,失败回退CPU) / cuda / cpu
WHISPER_DEVICE=auto
# compute_type: auto / float16 / int8 / int8_float16
WHISPER_COMPUTE_TYPE=auto
# 识别语言：zh / en / 留空=自动检测
WHISPER_LANGUAGE=zh

# ── 快捷键（按住录音，松开转写）─────────────────────
# 单个键名（keyboard 库写法）：f9 / f8 / scroll lock / right ctrl
HOTKEY=alt
QUIT_HOTKEY=ctrl+shift+q

# ── 行为 ───────────────────────────────────────────
# 复制后是否自动 Ctrl+V 粘贴到当前光标处（默认仅复制）
AUTO_PASTE=true
# 录音开始/结束提示音
PLAY_BEEP=true
# 采样率（Whisper 需 16000，一般不用改）
SAMPLE_RATE=16000
MIN_RECORD_SEC=0.3
