# ── DeepSeek 润色（必填）────────────────────────────
# 控制台：https://platform.deepseek.com/  →  API Keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60

# ── STT 引擎 ───────────────────────────────────────
# whisper = faster-whisper（默认）；paraformer = FunASR Paraformer
# 切到 paraformer 需先安装：pip install funasr
STT_ENGINE=whisper

# ── STT (faster-whisper) ───────────────────────────
# 模型：tiny / base / small / medium / large-v3 / large-v3-turbo
WHISPER_MODEL=large-v3
# device: auto(优先GPU,失败回退CPU) / cuda / cpu
WHISPER_DEVICE=auto
# compute_type: auto / float16 / int8 / int8_float16
WHISPER_COMPUTE_TYPE=auto
# 识别语言：zh / en / 留空=自动检测
WHISPER_LANGUAGE=zh

# ── STT (FunASR Paraformer，仅 STT_ENGINE=paraformer 时生效) ──
# 中文离线模型，首次运行自动从 ModelScope 下载
PARAFORMER_MODEL=paraformer-zh
# device: auto(有GPU用GPU,否则CPU) / cuda / cpu
PARAFORMER_DEVICE=auto
# VAD / 标点模型，留空则不加载（标点有助于后续润色，建议保留）
PARAFORMER_VAD_MODEL=fsmn-vad
PARAFORMER_PUNC_MODEL=ct-punc

# ── 快捷键（按住录音，松开转写）─────────────────────
# 单个键名（keyboard 库写法）：f9 / f8 / scroll lock / right ctrl
HOTKEY=f9
QUIT_HOTKEY=ctrl+shift+q

# ── 行为 ───────────────────────────────────────────
# 复制后是否自动 Ctrl+V 粘贴到当前光标处（默认仅复制）
AUTO_PASTE=false
# 录音开始/结束提示音
PLAY_BEEP=true
# 采样率（Whisper 需 16000，一般不用改）
SAMPLE_RATE=16000
MIN_RECORD_SEC=0.3
